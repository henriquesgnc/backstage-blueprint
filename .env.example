# Required: GitHub organization or username where repos will be created
GITHUB_ORG=replace-with-your-github-org

# Required: GitHub Personal Access Token (repo, workflow scopes)
# Create at https://github.com/settings/tokens
GITHUB_TOKEN=replace-with-your-github-token

# Backstage backend secret (any random string)
BACKSTAGE_BACKEND_SECRET=replace-with-a-random-string

# Node.js options (required for Node 20+)
NODE_OPTIONS=--no-node-snapshot
